SCHEDULE_API_KEY=replace-with-a-long-random-secret
OPENAI_API_KEY=replace-with-an-openai-project-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=45
MAX_CONCURRENT_SOLVES=1
SCHEDULE_SOLVER_WORKERS=2
SCHEDULE_RANDOM_SEED=42
AUTO_SCHEDULE_TUTOR=1
MAX_UPLOAD_BYTES=10485760
MAX_UNCOMPRESSED_BYTES=104857600
RATE_LIMIT_PER_MINUTE=30
ALLOWED_ORIGINS=http://127.0.0.1:8765,http://localhost:8765,http://127.0.0.1:8768,http://localhost:8768,https://smallcannon-arch.github.io
GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
GOOGLE_WORKSPACE_DOMAIN=school.example.edu.tw
SCHEDULE_ADMIN_EMAILS=scheduler-admin@school.example.edu.tw
SCHEDULE_SUPER_ADMIN_EMAILS=platform-owner@school.example.edu.tw
SCHEDULE_MULTI_TENANT=true
SCHEDULE_STORE=firestore
FIRESTORE_PROJECT_ID=replace-with-google-cloud-project-id
SCHEDULE_SCHOOL_ID=school-code
SCHEDULE_SCHOOL_NAME=Example School
MAX_PUBLISHED_SNAPSHOT_BYTES=819200
